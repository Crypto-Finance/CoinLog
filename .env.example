# Bybit API Configuration
# Optional: Set a different Bybit API endpoint if you're getting 403 errors
# Default: https://api.bybit.com
# Alternative: https://api.bytick.com (for restricted regions)
BYBIT_API_URL=https://api.bybit.com

# CSP / Security
API_ROUTE_SECRET=your-secret-key-here
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Development origins (comma-separated)
ALLOWED_DEV_ORIGINS=localhost,127.0.0.1

# Rate Limiting (Optional - uses in-memory if not set)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: Error monitoring
# SENTRY_DSN=
